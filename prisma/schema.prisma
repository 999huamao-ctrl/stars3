generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  targetUrl   String
  description String?
  status      String   @default("active")
  clicks      Int      @default(0)
  conversions Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model Event {
  id          String   @id @default(cuid())
  linkId      String
  link        Link     @relation(fields: [linkId], references: [id])
  type        String   // click, conversion, view
  ip          String?
  userAgent   String?
  referrer    String?
  country     String?
  city        String?
  device      String?
  browser     String?
  os          String?
  timestamp   DateTime @default(now())
  converted   Boolean  @default(false)
}

model Analytics {
  id          String   @id @default(cuid())
  date        DateTime
  linkId      String?
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())

  @@index([date, linkId])
}